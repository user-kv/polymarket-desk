# desk/.env.example  —  copy to desk/.env and fill in. desk/.env is gitignored.
# FAKE MONEY ONLY. There is deliberately NO wallet key / exchange key here, ever.

# ---- Reasoning brain ---------------------------------------------------------
# The self-learning brain. Default once a key is present: gemini (free, no card).
# Get a free key (Google account, ~60s, no credit card): https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Force a specific backend (optional). If unset, the desk auto-detects:
#   gemini (if GEMINI_API_KEY set) -> ollama (if local server up) -> mock (heuristic).
# Values: gemini | ollama | claude | openai | mock
# DESK_LLM=gemini

# ---- Optional alternative brains (leave blank unless you use them) ----------
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ---- Optional model overrides ------------------------------------------------
# llm.py already tries a stable-first fallback chain (gemini-3.5-flash ->
# gemini-2.5-flash -> flash-lite -> -latest), so you normally don't set these.
# Set one only to pin a specific model first (it's tried ahead of the chain):
# DESK_GEMINI_CHEAP=gemini-2.5-flash-lite
# DESK_GEMINI_DEEP=gemini-3.5-flash
